                      "on-primary-fixed": "#001b3d",
                      "primary-fixed": "#d6e3ff",
                      "tertiary-fixed-dim": "#70df45",
                      "on-error-container": "#93000a",
                      "surface-container-highest": "#e1e2e9",
                      "on-tertiary-fixed-variant": "#175200",
                      "on-tertiary-container": "#3aa804",
                      "surface-container-lowest": "#ffffff",
                      "primary-fixed-dim": "#a9c7ff",
                      "on-secondary": "#ffffff",
                      "status-warning": "#FBBC04",
                      "on-primary-fixed-variant": "#264778",
                      "on-secondary-fixed": "#321200",
                      "on-tertiary-fixed": "#052100",
                      "surface-container": "#eceef4",
                      "on-surface-variant": "#43474f",
                      "secondary-fixed-dim": "#ffb68b",
                      "error": "#ba1a1a",
                      "tertiary-fixed": "#8bfd5f",
                      "tertiary-container": "#0b3300",
                      "secondary": "#994700",
                      "on-secondary-fixed-variant": "#753400",
                      "on-primary": "#ffffff",
                      "on-secondary-container": "#592600",
                      "status-critical": "#D93025",
                      "surface-bright": "#f8f9ff",
                      "surface-dim": "#d8dae0",
                      "on-tertiary": "#ffffff",
                      "primary": "#001736",
                      "surface-card": "#FFFFFF",
                      "surface-container-high": "#e6e8ef",
                      "secondary-container": "#fb7800",
                      "outline-variant": "#c4c6d0",
                      "inverse-primary": "#a9c7ff",
                      "error-container": "#ffdad6",
                      "outline": "#747780",
                      "background": "#f8f9ff",
                      "inverse-on-surface": "#eff0f7",
                      "background-subtle": "#F8F9FA",
                      "on-error": "#ffffff",
                      "tertiary": "#041c00",
                      "on-surface": "#191c21",
                      "surface-tint": "#405f91",
                      "secondary-fixed": "#ffdbc8"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px"
              },
              "spacing": {
                      "margin-desktop": "40px",
                      "container-max": "1440px",
                      "base": "8px",
                      "margin-mobile": "16px",
                      "gutter": "24px",
                      "card-padding": "24px"
              },
              "fontFamily": {
                      "label-sm": [
                              "JetBrains Mono"
                      ],
                      "label-md": [
                              "JetBrains Mono"
                      ],
                      "headline-lg-mobile": [
                              "Hanken Grotesk"
                      ],
                      "headline-lg": [
                              "Hanken Grotesk"
                      ],
                      "body-md": [
                              "Hanken Grotesk"
                      ],
                      "headline-md": [
                              "Hanken Grotesk"
                      ],
                      "body-lg": [
                              "Hanken Grotesk"
                      ],
                      "body-sm": [
                              "Hanken Grotesk"
                      ]
              },
              "fontSize": {
                      "label-sm": [
                              "12px",
                              {
                                      "lineHeight": "14px",
                                      "fontWeight": "500"
                              }
                      ],
                      "label-md": [
                              "14px",
                              {
                                      "lineHeight": "16px",
                                      "letterSpacing": "0.05em",
                                      "fontWeight": "500"
                              }
                      ],
                      "headline-lg-mobile": [
                              "24px",
                              {
                                      "lineHeight": "32px",
                                      "fontWeight": "700"
                              }
                      ],
                      "headline-lg": [
                              "32px",
                              {
                                      "lineHeight": "40px",
                                      "letterSpacing": "-0.02em",
                                      "fontWeight": "700"
                              }
                      ],
                      "body-md": [
                              "16px",
                              {
                                      "lineHeight": "24px",
                                      "fontWeight": "400"
                              }
                      ],
                      "headline-md": [
                              "24px",
                              {
                                      "lineHeight": "32px",
                                      "fontWeight": "600"
                              }
                      ],
                      "body-lg": [
                              "18px",
                              {
                                      "lineHeight": "28px",
                                      "fontWeight": "400"
                              }
                      ],
                      "body-sm": [
                              "14px",
                              {
                                      "lineHeight": "20px",
                                      "fontWeight": "400"
                              }
                      ]
              }
      },
          },
        }
      </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        
        .pulse-dot {
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(217, 48, 37, 0.7);
            }
            
            70% {
                transform: scale(1);
                box-shadow: 0 0 0 10px rgba(217, 48, 37, 0);
            }
            
            100% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(217, 48, 37, 0);
            }
        }

        .chart-grid {
            background-image: 
                linear-gradient(to right, #E9ECEF 1px, transparent 1px),
                linear-gradient(to bottom, #E9ECEF 1px, transparent 1px);
            background-size: 50px 50px;
        }
    </style>
</head>
<body class="bg-background text-on-background min-h-screen flex font-body-md">
<!-- SideNavBar (from JSON) -->
<nav class="fixed left-0 top-0 h-full w-[280px] bg-primary dark:bg-primary-container shadow-md z-50 flex flex-col p-4 gap-2 hidden md:flex">
<!-- Brand / Header -->
<div class="flex items-center gap-4 mb-8 px-2">
<div class="w-10 h-10 rounded bg-secondary flex items-center justify-center shrink-0">
<span class="material-symbols-outlined text-on-secondary" style="font-variation-settings: 'FILL' 1;">
                    dns
                </span>
</div>
<div>
<h1 class="font-headline-md text-headline-md font-bold text-on-primary dark:text-primary-fixed">MMC Portal</h1>
<p class="font-body-sm text-body-sm text-on-primary-container">IT Management</p>
</div>
</div>
<!-- Navigation Links -->
<div class="flex flex-col gap-2 flex-grow">
<!-- Active Tab: Dashboard -->
<a class="flex items-center gap-3 px-4 py-3 bg-secondary text-on-secondary rounded-lg active:scale-95 transition-transform" href="#">
<span class="material-symbols-outlined">dashboard</span>
<span class="font-label-md text-label-md">Dashboard</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-primary-container hover:text-on-primary hover:bg-primary-fixed-dim/10 transition-colors duration-200 active:scale-95 transition-transform rounded-lg" href="#">
<span class="material-symbols-outlined">warning</span>
<span class="font-label-md text-label-md">Incidents</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-primary-container hover:text-on-primary hover:bg-primary-fixed-dim/10 transition-colors duration-200 active:scale-95 transition-transform rounded-lg" href="#">
<span class="material-symbols-outlined">trending_up</span>
<span class="font-label-md text-label-md">Improvements</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-primary-container hover:text-on-primary hover:bg-primary-fixed-dim/10 transition-colors duration-200 active:scale-95 transition-transform rounded-lg" href="#">
<span class="material-symbols-outlined">menu_book</span>
<span class="font-label-md text-label-md">Knowledge Base</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-primary-container hover:text-on-primary hover:bg-primary-fixed-dim/10 transition-colors duration-200 active:scale-95 transition-transform rounded-lg" href="#">
<span class="material-symbols-outlined">dns</span>
<span class="font-label-md text-label-md">Systems</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-primary-container hover:text-on-primary hover:bg-primary-fixed-dim/10 transition-colors duration-200 active:scale-95 transition-transform rounded-lg" href="#">
<span class="material-symbols-outlined">handshake</span>
<span class="font-label-md text-label-md">Partners</span>
</a>
<a class="flex items-center gap-3 px-4 py-3 text-on-primary-container hover:text-on-primary hover:bg-primary-fixed-dim/10 transition-colors duration-200 active:scale-95 transition-transform rounded-lg" href="#">
<span class="material-symbols-outlined">settings</span>
<span class="font-label-md text-label-md">Admin</span>
</a>
</div>
<!-- CTA -->
<div class="mt-auto pt-4 border-t border-on-primary-container/20">
<button class="w-full bg-secondary text-on-secondary font-label-md text-label-md py-3 px-4 rounded-lg flex items-center justify-center gap-2 hover:bg-secondary-container transition-colors active:scale-95">
<span class="material-symbols-outlined text-[18px]">add</span>
                New Incident
            </button>
</div>
</nav>
<!-- Main Content Area -->
<div class="flex-1 md:ml-[280px] flex flex-col min-w-0">
<!-- TopNavBar (from JSON) -->
<header class="sticky top-0 w-full z-40 bg-surface dark:bg-surface-container-low border-b border-border-quiet dark:border-outline-variant transition-all duration-300 ease-in-out">
<div class="flex justify-between items-center h-16 px-margin-desktop md:px-8">
<!-- Left: Product Name / Mobile Menu Toggle -->
<div class="flex items-center gap-4">
<button class="md:hidden text-primary p-2 hover:bg-surface-container-highest/50 rounded-full">
<span class="material-symbols-outlined">menu</span>
</button>
<h2 class="font-headline-md text-headline-md font-extrabold text-primary dark:text-primary-fixed md:hidden">MMC Support</h2>
<!-- Search Bar (on_left configuration) -->
<div class="hidden md:flex relative items-center">
<span class="material-symbols-outlined absolute left-3 text-on-surface-variant text-[20px]">search</span>
<input class="pl-10 pr-4 py-2 bg-surface-container-low border-border-quiet rounded-lg focus:border-primary focus:ring-1 focus:ring-primary font-body-sm text-body-sm w-64 placeholder:text-on-surface-variant transition-colors" placeholder="Search incidents, solutions..." type="text"/>
</div>
</div>
<!-- Right: Actions & Profile -->
<div class="flex items-center gap-2">
<button class="text-on-surface-variant hover:text-primary hover:bg-surface-container-highest/50 rounded-full p-2 transition-colors">
<span class="material-symbols-outlined">help_outline</span>
</button>
<button class="text-on-surface-variant hover:text-primary hover:bg-surface-container-highest/50 rounded-full p-2 transition-colors relative">
<span class="material-symbols-outlined">notifications</span>
<span class="absolute top-2 right-2 w-2 h-2 bg-status-critical rounded-full pulse-dot"></span>
</button>
<div class="ml-4 w-8 h-8 rounded-full overflow-hidden bg-surface-variant border border-border-quiet shrink-0 cursor-pointer">
<img alt="User Profile" class="w-full h-full object-cover" data-alt="Professional headshot of a technical support engineer, clean lighting, corporate IT environment, modern aesthetic, blue and gray tones." src="https://lh3.googleusercontent.com/aida-public/AB6AXuC-y7xJRfGM9cXxopiOBHf9croEKKoPHHdkZ_o-MLDQChNEwAG-QfABb-W40OeC31A8A_wRVCCUU2uyGY1SwyzUjhp91lfl_sRUpZAcfYIIh8ByQlDBDhpmkLkXtnSPy0SPjf1VcvkjM49TUJAkkeLeD_Mr9g-HNbbbSVD29ekNG3s7k3hJzxY-21LYQZOXrtj0btqf-wS14hyBXcj6dzwJlh7VTb5OWwHWqF2Vj-i2WO8AqQ7QPEsghG7e6FySFkoMBANkRtoqLw"/>
</div>
</div>
</div>
</header>
<!-- Page Content -->
<main class="flex-1 p-margin-mobile md:p-gutter max-w-container-max mx-auto w-full">
<!-- Welcome Header -->
<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
<div>
<h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-primary mb-1">Welcome back, Admin</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Here is the current status of your IT environment.</p>
</div>
<div class="flex gap-3">
<button class="px-4 py-2 border border-border-quiet bg-surface-card rounded-lg font-label-md text-label-md text-primary hover:border-primary transition-colors flex items-center gap-2 shadow-sm">
<span class="material-symbols-outlined text-[18px]">download</span>
                        Export Report
                    </button>
</div>
</div>
<!-- Bento Grid Layout -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter">
<!-- Metrics Row (Spans full width, 4 cards) -->
<div class="col-span-1 md:col-span-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter">
<!-- Metric 1: Total Incidents -->
<div class="bg-surface-card rounded-lg p-card-padding shadow-[0_4px_24px_rgba(0,23,54,0.04)] border border-border-quiet/50 hover:border-primary/30 transition-colors group relative overflow-hidden">
<div class="flex justify-between items-start mb-4">
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Total Incidents</span>
<div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-[20px]">confirmation_number</span>
</div>
</div>
<div class="flex items-baseline gap-2">
<h3 class="font-headline-lg text-headline-lg text-primary">1,248</h3>
<span class="font-label-sm text-label-sm text-on-tertiary-container flex items-center">
<span class="material-symbols-outlined text-[14px]">arrow_upward</span> 12%
                            </span>
</div>
</div>
<!-- Metric 2: Open Critical (Red Accent) -->
<div class="bg-surface-card rounded-lg p-card-padding shadow-[0_4px_24px_rgba(0,23,54,0.04)] border border-border-quiet/50 hover:border-status-critical/30 transition-colors group relative overflow-hidden">
<div class="absolute top-0 left-0 w-1 h-full bg-status-critical"></div>
<div class="flex justify-between items-start mb-4">
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Open Critical</span>
<div class="w-8 h-8 rounded-full bg-status-critical/10 flex items-center justify-center text-status-critical pulse-dot">
<span class="material-symbols-outlined text-[20px]">warning</span>
</div>
</div>
<div class="flex items-baseline gap-2">
<h3 class="font-headline-lg text-headline-lg text-primary">3</h3>
<span class="font-label-sm text-label-sm text-status-critical flex items-center">
                                Needs Attention
                            </span>
</div>
</div>
<!-- Metric 3: Resolved Today (Green Accent) -->
<div class="bg-surface-card rounded-lg p-card-padding shadow-[0_4px_24px_rgba(0,23,54,0.04)] border border-border-quiet/50 hover:border-tertiary-container/30 transition-colors group relative overflow-hidden">
<div class="absolute top-0 left-0 w-1 h-full bg-tertiary-container"></div>
<div class="flex justify-between items-start mb-4">
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Resolved Today</span>
<div class="w-8 h-8 rounded-full bg-tertiary-container/10 flex items-center justify-center text-tertiary-container">
<span class="material-symbols-outlined text-[20px]">check_circle</span>
</div>
</div>
<div class="flex items-baseline gap-2">
<h3 class="font-headline-lg text-headline-lg text-primary">42</h3>
<span class="font-label-sm text-label-sm text-on-surface-variant flex items-center">
                                of 50 assigned
                            </span>
</div>
</div>
<!-- Metric 4: Avg Response Time -->
<div class="bg-surface-card rounded-lg p-card-padding shadow-[0_4px_24px_rgba(0,23,54,0.04)] border border-border-quiet/50 hover:border-primary/30 transition-colors group relative overflow-hidden">
<div class="flex justify-between items-start mb-4">
<span class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Avg Response Time</span>
<div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-[20px]">timer</span>
</div>
</div>
<div class="flex items-baseline gap-2">
<h3 class="font-headline-lg text-headline-lg text-primary">14m</h3>
<span class="font-label-sm text-label-sm text-on-tertiary-container flex items-center">
<span class="material-symbols-outlined text-[14px]">arrow_downward</span> 2m
                            </span>
</div>
</div>
</div>
<!-- Main Chart Area (Spans 8 columns on desktop) -->
<div class="col-span-1 md:col-span-8 bg-surface-card rounded-lg shadow-[0_4px_24px_rgba(0,23,54,0.04)] border border-border-quiet/50 flex flex-col h-full min-h-[400px]">
<div class="p-card-padding border-b border-border-quiet flex justify-between items-center">
<h3 class="font-headline-md text-headline-md text-primary flex items-center gap-2">
<span class="material-symbols-outlined text-secondary">monitoring</span>
                            Weekly Volume
                        </h3>
<div class="flex gap-2">
<button class="px-3 py-1 text-label-sm font-label-sm bg-surface-container-low text-primary rounded border border-border-quiet">This Week</button>
<button class="px-3 py-1 text-label-sm font-label-sm text-on-surface-variant hover:bg-surface-container-low rounded">Last Week</button>
</div>
</div>
<div class="flex-1 p-6 relative">
<!-- Abstract Chart Representation -->
<div class="absolute inset-0 m-6 chart-grid opacity-30"></div>
<div class="relative w-full h-full flex items-end pb-8">
<!-- Y-Axis labels -->
<div class="absolute left-0 top-0 bottom-8 w-8 flex flex-col justify-between text-label-sm font-label-sm text-on-surface-variant text-right pr-2">
<span>100</span>
<span>75</span>
<span>50</span>
<span>25</span>
<span>0</span>
</div>
<!-- X-Axis labels & Bars/Lines abstraction -->
<div class="ml-10 flex-1 flex justify-between items-end h-full relative">
<!-- Line abstraction -->
<svg class="absolute inset-0 w-full h-full" preserveaspectratio="none" viewbox="0 0 100 100">
<path d="M0,80 Q20,60 40,70 T60,40 T80,50 T100,20" fill="none" stroke="#001736" stroke-width="2" vector-effect="non-scaling-stroke"></path>
<path d="M0,90 Q20,85 40,95 T60,75 T80,85 T100,60" fill="none" stroke="#E9ECEF" stroke-dasharray="4 4" stroke-width="2" vector-effect="non-scaling-stroke"></path>
</svg>
<div class="w-full flex justify-between absolute -bottom-6 text-label-sm font-label-sm text-on-surface-variant">
<span>Mon</span>
<span>Tue</span>
<span>Wed</span>
<span>Thu</span>
<span>Fri</span>
<span>Sat</span>
<span>Sun</span>
</div>
</div>
</div>
</div>
</div>
<!-- Side Column (Spans 4 columns on desktop) -->
<div class="col-span-1 md:col-span-4 flex flex-col gap-gutter">
<!-- AI Support Card -->
<div class="bg-primary-container text-on-primary-container rounded-lg p-card-padding shadow-md relative overflow-hidden">
<!-- Decorative background element -->
<div class="absolute top-0 right-0 w-32 h-32 bg-primary-fixed/10 rounded-full blur-2xl -mr-10 -mt-10"></div>
<div class="relative z-10">
<h3 class="font-headline-md text-headline-md text-on-primary flex items-center gap-2 mb-2">
<span class="material-symbols-outlined text-primary-fixed-dim" style="font-variation-settings: 'FILL' 1;">smart_toy</span>
                                AI Support
                            </h3>
<p class="font-body-sm text-body-sm mb-4 text-primary-fixed-dim">Quickly find solutions from the knowledge base using natural language.</p>
<div class="relative">
<input class="w-full pl-3 pr-10 py-2.5 bg-primary/50 border border-primary-fixed-dim/30 rounded-lg text-on-primary placeholder:text-on-primary-container/70 focus:border-primary-fixed focus:ring-1 focus:ring-primary-fixed font-body-sm text-body-sm outline-none" placeholder="Describe the issue..." type="text"/>
<button class="absolute right-2 top-1.5 p-1 rounded hover:bg-primary-fixed/20 text-primary-fixed transition-colors">
<span class="material-symbols-outlined text-[20px]">send</span>
</button>
</div>
</div>
</div>
<!-- Recent Incidents -->
<div class="bg-surface-card rounded-lg shadow-[0_4px_24px_rgba(0,23,54,0.04)] border border-border-quiet/50 flex-1 flex flex-col">
<div class="p-4 border-b border-border-quiet flex justify-between items-center">
<h3 class="font-headline-md text-body-lg text-primary font-semibold">Recent Incidents</h3>
<a class="font-label-sm text-label-sm text-secondary hover:underline" href="#">View All</a>
</div>
<div class="flex-1 overflow-y-auto p-2">
<!-- Incident Item 1 (Critical) -->
<div class="p-3 hover:bg-surface-container-low rounded-lg transition-colors cursor-pointer border border-transparent hover:border-border-quiet group">
<div class="flex justify-between items-start mb-1">
<span class="font-label-sm text-label-sm text-primary font-bold">INC-8092</span>
<span class="bg-status-critical/10 text-status-critical font-label-sm text-[10px] px-2 py-0.5 rounded uppercase tracking-wider border border-status-critical/20">Critical</span>
</div>
<p class="font-body-sm text-body-sm text-primary line-clamp-1 mb-2">Database connection timeout on Main DB Cluster</p>
<div class="flex justify-between items-center font-label-sm text-[11px] text-on-surface-variant">
<span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">schedule</span> 10m ago</span>
<span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">person</span> System</span>
</div>
</div>
<!-- Incident Item 2 (Warning) -->
<div class="p-3 hover:bg-surface-container-low rounded-lg transition-colors cursor-pointer border border-transparent hover:border-border-quiet group border-t border-border-quiet/30">
<div class="flex justify-between items-start mb-1">
<span class="font-label-sm text-label-sm text-primary font-bold">INC-8091</span>
<span class="bg-status-warning/10 text-secondary-container font-label-sm text-[10px] px-2 py-0.5 rounded uppercase tracking-wider border border-status-warning/20">High</span>
</div>
<p class="font-body-sm text-body-sm text-primary line-clamp-1 mb-2">High CPU usage on Web Server 04</p>
